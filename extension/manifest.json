{
  "manifest_version": 3,
  "name": "Zenith Anti-PMO",
  "version": "1.5.0",
  "description": "A premium, minimalist mindfulness companion to help you surf the urge and build healthy habits. No gradients, no distraction, pure focus.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "dashboard/dashboard.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/words.js", "content_scanner.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "http://localhost:7860/*",
        "http://127.0.0.1:7860/*",
        "http://localhost:8188/*",
        "http://127.0.0.1:8188/*",
        "http://localhost:5000/*",
        "http://127.0.0.1:5000/*"
      ],
      "js": ["utils/words.js", "prompt_guard.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": ""
}